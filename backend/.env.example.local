# --- Service ---------------------------------------------------------------
APP_NAME=web-operaton-modeler-backend
PORT=3000
BASE_URL_PREFIX=/api
NODE_ENV=development
LOG_FORMAT=combined

# --- OAuth2 client_credentials (BFF -> api-service-operaton) ---------------
# CLIENT_KEY/SECRET are the OAuth2 client registration this BFF uses to
# authenticate to api-service-operaton. In prod, point TOKEN_URL at the
# Sundsvallskommun API gateway's /token endpoint; locally point it at
# whatever stub you're using.
CLIENT_KEY=
CLIENT_SECRET=
TOKEN_URL=http://localhost:8081/token
API_BASE_URL=http://localhost:8081
MUNICIPALITY_ID=2281

# --- SAML (User -> BFF -> IdP) ---------------------------------------------
SAML_CALLBACK_URL=http://localhost:3001/api/saml/login/callback
SAML_LOGOUT_CALLBACK_URL=http://localhost:3001/api/saml/logout/callback
SAML_FAILURE_REDIRECT=http://localhost:3000/login?failed=1
SAML_ENTRY_SSO=http://localhost:7000/sso
SAML_ISSUER=web-operaton-modeler
# PEM-encoded; for local dev, copy from web-app-fake-sso-idp's example.
SAML_IDP_PUBLIC_CERT=
SAML_PRIVATE_KEY=
SAML_PUBLIC_KEY=

# --- Session ---------------------------------------------------------------
# Random, long string used to sign session cookies. Rotate per env.
SECRET_KEY=please-change-me
# `true` keeps sessions in process memory (lost on restart). Set to `false`
# to use the file-store at ./data/sessions for persistence across restarts.
SESSION_MEMORY=true

# --- CORS ------------------------------------------------------------------
# Comma-separated list of origins allowed to call the BFF. The SPA's origin
# must be here. CREDENTIALS=true tells the browser the session cookie is
# legal across this origin.
ORIGIN=http://localhost:3000
CREDENTIALS=true
